# ===================================================
# 서버 설정
# ===================================================
PORT=3000
SITE_DOMAIN=https://newment.co.kr
SESSION_SECRET=랜덤하게_긴_문자열_입력

# Vercel Cron 보안 키 (Vercel 배포 시 필요)
CRON_SECRET=랜덤하게_긴_문자열_입력

# ===================================================
# 리포트 스케줄 (cron 형식)
# ===================================================
CRON_DAILY=0 8 * * *
CRON_WEEKLY=0 9 * * 1
CRON_MONTHLY=0 9 1 * *

